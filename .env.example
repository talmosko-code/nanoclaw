# NanoClaw Configuration
# Copy this file to .env and fill in your values

# Assistant
ASSISTANT_NAME=Andy
ASSISTANT_HAS_OWN_NUMBER=

# Timezone (IANA identifier, e.g. America/New_York)
# TZ=

# Agent Runner: 'anthropic' (default) or 'opencode'
# AGENT_RUNNER=anthropic

# OneCLI Gateway
ONECLI_URL=http://127.0.0.1:10254

# Container
# CONTAINER_IMAGE=nanoclaw-agent:latest
# CONTAINER_TIMEOUT=1800000
# IDLE_TIMEOUT=1800000

# Telegram (optional)
TELEGRAM_BOT_TOKEN=

# --- OpenCode Runner (when AGENT_RUNNER=opencode) ---
# Provider: anthropic, openrouter, openai, google, deepseek, groq, mistral, xai, together, fireworks, cohere, moonshot
# OPENCODE_PROVIDER=openrouter
# OPENCODE_MODEL=openrouter/qwen/qwen3.5-flash-02-23
# OPENCODE_SMALL_MODEL=openrouter/qwen/qwen3.5-flash-02-23  # optional — defaults to provider default

# API Keys (register with OneCLI: onecli secrets create --name <Name> --type api_key --value <key> --host-pattern <domain>)
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
# DEEPSEEK_API_KEY=
# GROQ_API_KEY=
# MISTRAL_API_KEY=
# XAI_API_KEY=
# TOGETHER_API_KEY=
# FIREWORKS_API_KEY=
# COHERE_API_KEY=
# MOONSHOT_API_KEY=                      # Kimi / Moonshot; e.g. OPENCODE_MODEL=moonshot/kimi-k2.5
# OPENCODE_ZEN_API_KEY=                  # OpenCode Zen API key; e.g. OPENCODE_MODEL=opencode/qwen3.6-plus-free
